datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id         String   @id @default(uuid())
  email      String   @unique // Hashed email, never plaintext
  created_at DateTime @default(now())
}

model VaultItem {
  id                String   @id @default(uuid())
  user_id           String
  type              String   // 'note' | 'password' | 'file_metadata'
  encrypted_payload String   // Client-side AES-256-GCM encrypted payload (Base64 string)
  iv                String   // Initialization Vector (Base64 string)
  created_at        DateTime @default(now())
}
