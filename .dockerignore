# Dependencies
node_modules

# Build output
.next

# Version control
.git
.gitignore

# SQLite database files (generated at runtime)
prisma/*.db
prisma/*.db-journal
prisma/*.db-wal
prisma/data/

# Docker files (no need to send to build context)
Dockerfile
docker-compose.yml
.dockerignore

# IDE & editor
.vscode
.idea
*.swp
*.swo

# Environment overrides (the base .env IS needed for Prisma generate)
.env.local
.env.*.local

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS files
.DS_Store
Thumbs.db

# Documentation (not needed in image)
README.md
CLAUDE.md
AGENTS.md
LICENSE
